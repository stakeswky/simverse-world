# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skills_world

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# GitHub OAuth (optional for MVP)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LLM Config
LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=512

# SearXNG (research)
SEARXNG_URL=http://localhost:58080

# Portrait generation (Gemini via proxy)
PORTRAIT_LLM_MODEL=gemini-3-pro-image-preview
PORTRAIT_LLM_BASE_URL=http://localhost:3000/v1
PORTRAIT_LLM_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:5173"]
