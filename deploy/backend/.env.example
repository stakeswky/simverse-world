# PostgreSQL (used by docker-compose, overridden in environment block)
POSTGRES_PASSWORD=changeme

# Auth
JWT_SECRET=generate-a-64-char-random-string-here

# LLM (DashScope compatible endpoint)
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# SearXNG (research)
SEARXNG_URL=http://100.93.72.102:58080

# Portrait generation (Gemini via proxy)
PORTRAIT_LLM_MODEL=gemini-3-pro-image-preview
PORTRAIT_LLM_BASE_URL=http://100.93.72.102:3000/v1
PORTRAIT_LLM_API_KEY=sk-xxx

# CORS — set to your Cloudflare Worker domain
CORS_ORIGINS=["https://skills-world.your-subdomain.workers.dev"]

# LinuxDo OAuth (optional)
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=
